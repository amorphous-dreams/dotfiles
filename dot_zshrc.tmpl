# ~/.zshrc — managed by chezmoi
# context: {{ .context }} | machine: {{ .chezmoi.hostname }}
# Edit source: chezmoi edit ~/.zshrc

# ── Shell options ────────────────────────────────────────────────────────────
setopt INTERACTIVE_COMMENTS   # allow # comments in interactive shell
setopt AUTO_CD                # type a directory name to cd into it
setopt CORRECT                # suggest corrections for mistyped commands

# ── History ───────────────────────────────────────────────────────────────────
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# ── nvm ───────────────────────────────────────────────────────────────────────
# >>> nvm start <<<
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
# <<< nvm end <<<

# ── SSH agent ─────────────────────────────────────────────────────────────────
# >>> ssh-agent start <<<
if [ -z "$SSH_AGENT_PID" ] || ! kill -0 "$SSH_AGENT_PID" 2>/dev/null; then
  eval "$(ssh-agent -s)" > /dev/null
fi
if [[ -f ~/.ssh/id_ed25519 ]]; then
  ssh-add -l &>/dev/null || ssh-add ~/.ssh/id_ed25519 2>/dev/null
fi
# <<< ssh-agent end <<<

# ── Context ───────────────────────────────────────────────────────────────────
export DOTFILES_CONTEXT="{{ .context }}"

{{- if eq .context "work" }}

# Work: Windows PATH excluded to prevent tool bleed into WSL
# Run wsl_windows_path.sh to selectively re-add Windows tools you need
{{- else }}

# Personal: Windows PATH available for VS Code, Explorer, etc.
{{- end }}

# ── Aliases ───────────────────────────────────────────────────────────────────
alias ll='ls -lah'
alias la='ls -A'
alias gs='git status'
alias gp='git pull'
alias gd='git diff'

# Use modern replacements if installed
command -v fdfind &>/dev/null && alias fd='fdfind'
command -v batcat &>/dev/null && alias bat='batcat' && alias cat='batcat --style=plain'
command -v eza  &>/dev/null && alias ls='eza --icons'
command -v eza  &>/dev/null && alias ll='eza -lah --icons --git'
command -v bat  &>/dev/null && alias cat='bat --style=plain'
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

# ── zsh plugins ───────────────────────────────────────────────────────────────
# zsh-autosuggestions
[[ -f ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
  source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh

# zsh-syntax-highlighting — must be last
[[ -f ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
  source ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# ── PATH additions ───────────────────────────────────────────────────────────
export PATH="$HOME/.local/bin:$PATH"

# ── Starship prompt ───────────────────────────────────────────────────────────
command -v starship &>/dev/null && eval "$(starship init zsh)"

[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[ -f /usr/share/doc/fzf/examples/completion.zsh ]   && source /usr/share/doc/fzf/examples/completion.zsh
