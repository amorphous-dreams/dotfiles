# ~/.gitconfig — managed by chezmoi
# context: {{ .context }}

[user]
  name  = {{ .name }}
  email = {{ .email }}

[init]
  defaultBranch = main

[core]
  autocrlf = input
  editor   = vim

[safe]
  directory = *

[pull]
  rebase = false

[push]
  autoSetupRemote = true

[alias]
  st   = status
  co   = checkout
  br   = branch
  lg   = log --oneline --graph --decorate --all
  undo = reset --soft HEAD~1
  wip  = commit -am "wip"

{{- if eq .context "work" }}

# Work: sign commits if GPG key is configured
[commit]
  gpgsign = false

{{- else }}

# Personal: prefer SSH over HTTPS for GitHub
[url "git@github.com:"]
  insteadOf = https://github.com/

{{- end }}
